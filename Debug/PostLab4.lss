//ADC
static void iniciar_adc(void)
{
    //AVcc como referencia, resultado alineado a la izquierda, canal ADC7
    ADMUX  = (1<<REFS0)|(1<<ADLAR)|(1<<MUX2)|(1<<MUX1)|(1<<MUX0);
